{
  "name": "@aegis-scan/cli",
  "version": "0.17.7",
  "description": "AEGIS CLI — paranoid stack-specific security scanner for Next.js + Supabase. 0-1000 score, 42 built-in checkers (+20 external-tool wrappers: 16 SAST/DAST + 1 passive subdomain-recon + 3 LLM-agent pentest frameworks), AST-based cross-file taint analysis, 4 compliance frameworks (GDPR / SOC 2 / ISO 27001 / PCI-DSS), inline + config suppressions, JSON / SARIF / HTML / Markdown reporters. Use alongside Semgrep, not instead of it.",
  "license": "MIT",
  "author": "RideMatch1 <230386010+RideMatch1@users.noreply.github.com>",
  "homepage": "https://github.com/RideMatch1/a.e.g.i.s#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RideMatch1/a.e.g.i.s.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/RideMatch1/a.e.g.i.s/issues"
  },
  "keywords": [
    "security",
    "sast",
    "scanner",
    "audit",
    "cli",
    "nextjs",
    "supabase",
    "taint-analysis",
    "owasp",
    "cwe",
    "compliance",
    "gdpr",
    "soc2",
    "iso27001",
    "pci-dss",
    "sarif",
    "github-code-scanning"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
