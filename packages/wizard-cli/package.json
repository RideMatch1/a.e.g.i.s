  "repository": {
    "type": "git",
    "url": "git+https://github.com/RideMatch1/a.e.g.i.s.git",
    "directory": "packages/wizard-cli"
  },
  "bugs": {
    "url": "https://github.com/RideMatch1/a.e.g.i.s/issues"
  },
  "keywords": [
    "scaffold",
    "wizard",
    "nextjs",
    "supabase",
    "shadcn",
    "saas",
    "cli",
    "brief-generator",
    "agent-consumable",
