//     return (
//       <html>
//         <body>
//           <Script id="bootstrap" nonce={nonce} strategy="beforeInteractive">
//             {`/* inline bootstrap */`}
//           </Script>
//           {children}
//         </body>
//       </html>
//     );
//   }
//
// VERIFY:
//   curl -sIS https://<your-domain> | grep -i 'content-security-policy'
//   # erwarte: 'nonce-...' + 'strict-dynamic' enthalten, KEIN 'unsafe-inline'
