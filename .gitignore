node_modules/
dist/
.turbo/
*.tsbuildinfo
coverage/
.env
.env.*
.npmrc
.DS_Store

# Precision-annotation files are project-local: they hold absolute
# corpus paths and per-finding TP/FP verdicts. Regenerate on demand
# via `pnpm dogfood:annotate`.
aegis-precision/
~/aegis-corpus/

# VS Code extension build artefact — .vsix is produced on-demand by
# `npm run package` inside packages/vscode-extension/ and uploaded as
# a release asset by .github/workflows/release.yml. Do NOT commit.
*.vsix

# Rule #13 developer-local scrub-terms
scripts/scrub-terms.local.txt

# pnpm pack / npm pack output — per-package tarballs produced during
# local publish rehearsals. They can accidentally get git-added and
# should never land in a commit.
packages/*/*.tgz

# Scanner integration-test fixture scratch-dirs. Tests under
# packages/scanners/__tests__/ write into these paths as ephemeral
# tsconfig-resolution roots (multi-file-fixtures.ts, type-resolve.test.ts).
# They surface in `git status --short` after `pnpm -r test` runs; scoped
# to the known benchmark vulnerable-app src-root so unrelated paths
# with the same prefix are NOT auto-ignored.
packages/benchmark/vulnerable-app/src/__aegis_*/

# CycloneDX SBOM files generated at publish-time by
# scripts/generate-sbom.sh. Per-version artifacts; never source-of-truth.
sbom.cdx.json
**/sbom.cdx.json
